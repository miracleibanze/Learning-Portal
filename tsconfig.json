{
  "compilerOptions": {
    /* Language and Environment */
    "target": "es2016", // Set the JavaScript language version for emitted JavaScript
    "lib": ["dom", "dom.iterable", "esnext"], // Include necessary libraries
    "jsx": "preserve", // Preserve JSX syntax for Next.js
    /* Modules */
    "module": "ESNext", // Use ESNext modules
    "moduleResolution": "node", // Use Node.js-style module resolution
    "baseUrl": "./", // Base directory for non-relative module names
    "paths": {
      "@testing-library/react": ["node_modules/@testing-library/react"],
      "@testing-library/jest-dom": ["node_modules/@testing-library/jest-dom"],
      "@testing-library/user-events": [
        "node_modules/@testing-library/user-events"
      ],
      "@reduxjs/toolkit": ["node_modules/@reduxjs/toolkit"],
      "@*": ["./*"] // Map imports starting with "@" to the root directory
    },
    "resolveJsonModule": true, // Allow importing JSON files
    /* Type Checking */
    "strict": true, // Enable all strict type-checking options
    "esModuleInterop": true, // Enable compatibility with CommonJS modules
    "skipLibCheck": true, // Skip type checking all .d.ts files
    "forceConsistentCasingInFileNames": true, // Ensure consistent casing in file names
    /* Emit */
    "noEmit": true, // Disable emitting JavaScript files (Next.js handles this)
    /* TypeScript for Testing */
    "types": ["jest", "@testing-library/jest-dom"], // Include types for Jest and Testing Library
    /* Additional Options */
    "incremental": true, // Enable incremental compilation
    "isolatedModules": true, // Ensure each file can be safely transpiled independently
    "allowJs": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts", // Include Next.js type definitions
    "public.d.ts",
    "**/*.ts", // Include all TypeScript files
    "**/*.tsx", // Include all TypeScript JSX files
    "next.config.ts", // Include Next.js configuration file
    "jest.config.ts", // Include Jest configuration file
    ".next/types/**/*.ts",
    "tailwind.config.js",
    "postcss.config.mjs",
    "tailwind.config.mjs"
  ],
  "exclude": ["node_modules"] // Exclude node_modules from compilation
}
